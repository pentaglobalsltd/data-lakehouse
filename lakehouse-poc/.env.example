# ─── Lakehouse POC Credentials ────────────────────────────────────────────
# Copy this file to .env and fill in secure values before running bootstrap.sh
# This file is checked in. .env is gitignored.

# ─── MinIO (object storage) ───────────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

# ─── PostgreSQL source (lakedb) ───────────────────────────────────────────
POSTGRES_USER=lakeuser
POSTGRES_PASSWORD=lakepass
POSTGRES_DB=lakedb

# ─── Trino admin user (HTTPS:8443 external access) ────────────────────────
TRINO_ADMIN_PASSWORD=trinopass123

# ─── Nginx basic auth (protects Flink UI :8090 and Kafka Connect :8091) ───
NGINX_USERNAME=admin
NGINX_PASSWORD=nginxpass123

# ─── ClickHouse default user password ─────────────────────────────────────
CLICKHOUSE_PASSWORD=clickpass123

# ─── Airflow admin user ───────────────────────────────────────────────────
AIRFLOW_ADMIN_PASSWORD=airflowpass123
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=change-me-generate-with-fernet

# ─── Superset ─────────────────────────────────────────────────────────────
SUPERSET_ADMIN_PASSWORD=admin

# ─── Optional: Slack webhook for monitoring alerts ────────────────────────
SLACK_WEBHOOK_URL=
